rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function email() {
      return request.auth.token.email.lower();
    }

    function isMainAdmin() {
      return signedIn() && email() == "yasin_mansuri@live.com";
    }

    function tenantPath(tenantId) {
      return /databases/$(database)/documents/tenants/$(tenantId);
    }

    function memberPath(tenantId, uid) {
      return /databases/$(database)/documents/tenants/$(tenantId)/members/$(uid);
    }

    function invitePath(tenantId, inviteId) {
      return /databases/$(database)/documents/tenants/$(tenantId)/invites/$(inviteId);
    }

    function tenantExists(tenantId) {
      return exists(tenantPath(tenantId));
    }

    function tenantActive(tenantId) {
      return tenantExists(tenantId) && get(tenantPath(tenantId)).data.status == "active";
    }

    function billingWritable(tenantId) {
      return isMainAdmin()
        || (tenantExists(tenantId)
          && get(tenantPath(tenantId)).data.billingLocked != true
          && (
            !get(tenantPath(tenantId)).data.keys().hasAll(["freeAccessUntilAt"])
            || !(get(tenantPath(tenantId)).data.freeAccessUntilAt is timestamp)
            || get(tenantPath(tenantId)).data.freeAccessUntilAt > request.time
            || get(tenantPath(tenantId)).data.stripeSubscriptionId is string
          ));
    }

    function member(tenantId) {
      return get(memberPath(tenantId, request.auth.uid)).data;
    }

    function isActiveMember(tenantId) {
      return signedIn()
        && exists(memberPath(tenantId, request.auth.uid))
        && member(tenantId).status == "active";
    }

    function isActiveTenantMember(tenantId) {
      return isActiveMember(tenantId) && tenantActive(tenantId);
    }

    function role(tenantId) {
      return member(tenantId).role;
    }

    function isTenantAdmin(tenantId) {
      return isMainAdmin()
        || (isActiveTenantMember(tenantId) && role(tenantId) in ["schoolAdmin", "soloInstructor"]);
    }

    function isSchoolInstructor(tenantId) {
      return isActiveTenantMember(tenantId) && role(tenantId) == "schoolInstructor";
    }

    function assignedStudentToInstructor() {
      return resource.data.assignedInstructorIds is list
        && request.auth.uid in resource.data.assignedInstructorIds;
    }

    function assignedRecordToInstructor() {
      return resource.data.instructorId is string
        && resource.data.instructorId == request.auth.uid;
    }

    function newAssignedStudentToInstructor() {
      return request.resource.data.assignedInstructorIds is list
        && request.auth.uid in request.resource.data.assignedInstructorIds;
    }

    function newAssignedRecordToInstructor() {
      return request.resource.data.instructorId is string
        && request.resource.data.instructorId == request.auth.uid;
    }

    function onlyChanges(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function inviteNotExpired(tenantId, inviteId) {
      return !get(invitePath(tenantId, inviteId)).data.keys().hasAll(["expiresAt"])
        || get(invitePath(tenantId, inviteId)).data.expiresAt > request.time;
    }

    function canEditTenantProfile(tenantId) {
      return isTenantAdmin(tenantId)
        && onlyChanges([
          "name",
          "receiptBusinessName",
          "receiptFooterText",
          "receiptLogoDataUrl",
          "receiptPhone",
          "receiptEmail",
          "receiptWebsite",
          "receiptAddress",
          "messageSenderName",
          "hstNumber",
          "taxLabel",
          "taxRate",
          "taxEnabledByDefault",
          "profileSetupCompletedAt",
          "updatedAt"
        ]);
    }

    match /users/{uid} {
      allow get: if isMainAdmin() || (signedIn() && request.auth.uid == uid);
      allow list: if isMainAdmin();
      allow create: if isMainAdmin()
        || (signedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.email == email());
      allow update: if isMainAdmin()
        || (signedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.email == email());
      allow delete: if isMainAdmin();
    }

    match /tenants/{tenantId} {
      allow get: if isMainAdmin() || (isActiveMember(tenantId) && resource.data.status == "active");
      allow list: if isMainAdmin();
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail == email()
        && request.resource.data.status == "active"
        && request.resource.data.type in ["school", "solo"]
        && request.resource.data.plan == (request.resource.data.type == "school" ? "school" : "instructor")
        && request.resource.data.subscriptionStatus == "not_started"
        && request.resource.data.billingLocked == true
        && request.resource.data.extraSeats == 0
        && request.resource.data.seatLimit == (request.resource.data.type == "school" ? 10 : 1);
      allow update: if isMainAdmin() || canEditTenantProfile(tenantId);
      allow delete: if isMainAdmin();

      match /members/{uid} {
        allow get: if isMainAdmin()
          || isTenantAdmin(tenantId)
          || (signedIn() && request.auth.uid == uid && resource.data.status == "active");
        allow list: if isMainAdmin() || isTenantAdmin(tenantId);
        allow create: if isMainAdmin()
          || (
            signedIn()
            && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.email == email()
            && (
              (
                request.resource.data.role in ["schoolAdmin", "soloInstructor"]
                && getAfter(tenantPath(tenantId)).data.ownerUid == request.auth.uid
              )
              || (
                request.resource.data.role == "schoolInstructor"
                && request.resource.data.inviteId is string
                && exists(invitePath(tenantId, request.resource.data.inviteId))
                && get(invitePath(tenantId, request.resource.data.inviteId)).data.email == email()
                && get(invitePath(tenantId, request.resource.data.inviteId)).data.status == "pending"
                && inviteNotExpired(tenantId, request.resource.data.inviteId)
              )
            )
          );
        allow update: if isMainAdmin()
          || (isTenantAdmin(tenantId)
            && resource.data.role == "schoolInstructor"
            && request.resource.data.role == resource.data.role
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.email == resource.data.email
            && request.resource.data.tenantId == resource.data.tenantId
            && request.resource.data.status == "disabled"
            && onlyChanges(["status", "disabledAt", "updatedAt", "displayName"]));
        allow delete: if isMainAdmin() || (isTenantAdmin(tenantId) && billingWritable(tenantId));
      }

      match /invites/{inviteId} {
          allow get: if isMainAdmin()
          || isTenantAdmin(tenantId)
          || (signedIn()
            && resource.data.email == email()
            && resource.data.status == "pending"
            && (!resource.data.keys().hasAll(["expiresAt"]) || resource.data.expiresAt > request.time));
        allow list: if isMainAdmin() || isTenantAdmin(tenantId);
        allow create: if isMainAdmin();
        allow update: if isMainAdmin()
          || (isTenantAdmin(tenantId)
            && request.resource.data.status == "revoked"
            && onlyChanges(["status", "updatedAt"]))
          || (signedIn()
            && billingWritable(tenantId)
            && resource.data.email == email()
            && resource.data.status == "pending"
            && (!resource.data.keys().hasAll(["expiresAt"]) || resource.data.expiresAt > request.time)
            && request.resource.data.status == "accepted"
            && request.resource.data.acceptedByUid == request.auth.uid
            && onlyChanges(["status", "acceptedAt", "acceptedByUid", "updatedAt"]));
        allow delete: if isMainAdmin() || (isTenantAdmin(tenantId) && billingWritable(tenantId));
      }

      match /students/{docId} {
        allow get: if isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && assignedStudentToInstructor());
        allow list: if isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && assignedStudentToInstructor());
        allow create: if billingWritable(tenantId) && (isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && newAssignedStudentToInstructor()));
        allow update: if billingWritable(tenantId) && (isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && assignedStudentToInstructor() && newAssignedStudentToInstructor()));
        allow delete: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }

      match /payments/{docId} {
        allow get: if isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && assignedRecordToInstructor());
        allow list: if isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && assignedRecordToInstructor());
        allow create: if billingWritable(tenantId) && (isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && newAssignedRecordToInstructor()));
        allow update: if billingWritable(tenantId) && (isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && assignedRecordToInstructor() && newAssignedRecordToInstructor()));
        allow delete: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }

      match /events/{docId} {
        allow get: if isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && assignedRecordToInstructor());
        allow list: if isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && assignedRecordToInstructor());
        allow create: if billingWritable(tenantId) && (isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && newAssignedRecordToInstructor()));
        allow update: if billingWritable(tenantId) && (isTenantAdmin(tenantId) || (isSchoolInstructor(tenantId) && assignedRecordToInstructor() && newAssignedRecordToInstructor()));
        allow delete: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }

      match /evaluations/{docId} {
        allow get: if isMainAdmin()
          || isTenantAdmin(tenantId)
          || (isSchoolInstructor(tenantId)
            && resource.data.instructorUid == request.auth.uid
            && resource.data.studentId is string
            && get(/databases/$(database)/documents/tenants/$(tenantId)/students/$(resource.data.studentId)).data.assignedInstructorIds is list
            && request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)/students/$(resource.data.studentId)).data.assignedInstructorIds);
        allow list: if isMainAdmin()
          || isTenantAdmin(tenantId)
          || (isSchoolInstructor(tenantId) && resource.data.instructorUid == request.auth.uid);
        allow create: if billingWritable(tenantId)
          && (isTenantAdmin(tenantId)
            || (isSchoolInstructor(tenantId)
              && request.resource.data.instructorUid == request.auth.uid
              && request.resource.data.createdByUid == request.auth.uid));
        allow update: if billingWritable(tenantId)
          && (isMainAdmin()
            || isTenantAdmin(tenantId)
            || (isSchoolInstructor(tenantId) && resource.data.createdByUid == request.auth.uid));
        allow delete: if isMainAdmin() || isTenantAdmin(tenantId);
      }

      match /services/{docId} {
        allow read: if isActiveTenantMember(tenantId) || isMainAdmin();
        allow write: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }

      match /serviceCategories/{docId} {
        allow read: if isActiveTenantMember(tenantId) || isMainAdmin();
        allow write: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }

      match /business_expenses/{docId} {
        allow read, write: if isMainAdmin();
      }

      match /finance_years/{docId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }
      match /finance_assets/{docId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }
      match /finance_liabilities/{docId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }
      match /finance_payments/{docId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }
      match /finance_loans/{docId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }
      match /finance_spending/{docId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }
      match /smsLogs/{docId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId) && billingWritable(tenantId);
      }

      match /activity/{docId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if false;
      }
    }

    match /promoCodes/{codeId} {
      allow get: if signedIn();
      allow list, create, update, delete: if isMainAdmin();
    }

    match /{document=**} {
      allow read, write: if isMainAdmin();
    }
  }
}
