/**
 * Core Philosophy:
 * This ruleset enforces a simple but secure "Owner Administrator" model.
 * Access to the entire database is restricted to the SparkOn owner account only.
 * Unauthenticated users and any other signed-in users are denied all access.
 *
 * Data Structure:
 * The data is organized into five flat, top-level collections:
 * - /students/{studentId}: Records for driving students.
 * - /services/{serviceId}: Services offered by the academy.
 * - /serviceCategories/{categoryId}: Categories for services.
 * - /payments/{paymentId}: Transaction records.
 * - /business_expenses/{expenseId}: Business expense records.
 * - /events/{eventId}: Calendar events for lessons and appointments.
 * - /calendar_embeds/{calendarEmbedId}: (Legacy) A singleton collection for the calendar embed code.
 * This flat structure avoids complex relational lookups and simplifies security logic.
 *
 * Key Security Decisions:
 * - Owner Access Only: The signed-in user's email must match the configured
 *   SparkOn owner email.
 * - Default Deny: All access is denied by default. Rules explicitly grant
 *   permissions only to authenticated users.
 * - No Public Data: There are no publicly readable collections. All data,
 *   including services and calendar information, is protected and requires login.
 *
 * Denormalization for Authorization:
 * This security model is simple enough that it does not require denormalization.
 * Authorization is based solely on the user's authentication state (`request.auth`),
 * eliminating the need for cross-document reads (`get()`) to verify permissions.
 *
 * Structural Segregation:
 * Each top-level collection holds data with a uniform security requirement
 * (authenticated access only). This homogeneity simplifies the ruleset and ensures
 * consistent security across the application.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if the user is the SparkOn owner.
     */
    function isOwner() {
      return request.auth != null
        && request.auth.token.email == "yasin_mansuri@live.com";
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Grants full read and write access to the owner for student records.
     * @path /students/{studentId}
     * @allow An authenticated admin (create) a new student document.
     * @deny An unauthenticated user (get) a student document.
     * @principle Enforces an owner-only access model.
     */
    match /students/{studentId} {
      allow get: if isOwner();
      allow list: if isOwner();
      allow create: if isOwner();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    /**
     * @description Grants full read and write access to the owner for service offerings.
     * @path /services/{serviceId}
     * @allow An authenticated admin (update) the price of a service.
     * @deny An unauthenticated user (list) the available services.
     * @principle Enforces an owner-only access model.
     */
    match /services/{serviceId} {
      allow get: if isOwner();
      allow list: if isOwner();
      allow create: if isOwner();
      allow update: if isOwner();
      allow delete: if isOwner();
    }
    
    /**
     * @description Grants full read and write access to the owner for service categories.
     * @path /serviceCategories/{categoryId}
     * @allow An authenticated admin (create) a new service category.
     * @deny An unauthenticated user (list) the available categories.
     * @principle Enforces an owner-only access model.
     */
    match /serviceCategories/{categoryId} {
      allow get: if isOwner();
      allow list: if isOwner();
      allow create: if isOwner();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    /**
     * @description Grants full read and write access to the owner for payment records.
     * @path /payments/{paymentId}
     * @allow An authenticated admin (create) a new payment record.
     * @deny An unauthenticated user (delete) a payment record.
     * @principle Enforces an owner-only access model.
     */
    match /payments/{paymentId} {
      allow get: if isOwner();
      allow list: if isOwner();
      allow create: if isOwner();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    /**
     * @description Grants full read and write access to the owner for business expense records.
     * @path /business_expenses/{expenseId}
     * @allow An authenticated admin (create) a new business expense record.
     * @deny An unauthenticated user (list) the business expense records.
     * @principle Enforces an owner-only access model.
     */
    match /business_expenses/{expenseId} {
      allow get: if isOwner();
      allow list: if isOwner();
      allow create: if isOwner();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    /**
     * @description Grants full read and write access to the owner for calendar events.
     * @path /events/{eventId}
     * @allow An authenticated admin (create) a new event.
     * @deny An unauthenticated user (get) an event.
     * @principle Enforces an owner-only access model.
     */
    match /events/{eventId} {
      allow get: if isOwner();
      allow list: if isOwner();
      allow create: if isOwner();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    match /finance_years/{docId} { allow read, write: if isOwner(); }
    match /finance_assets/{docId} { allow read, write: if isOwner(); }
    match /finance_liabilities/{docId} { allow read, write: if isOwner(); }
    match /finance_payments/{docId} { allow read, write: if isOwner(); }
    match /finance_loans/{docId} { allow read, write: if isOwner(); }
    match /finance_spending/{docId} { allow read, write: if isOwner(); }
    match /smsLogs/{docId} { allow read, write: if isOwner(); }
  }
}
